)

// =====================================================================
// 10. Comparison to the literature
// =====================================================================
= How gabion compares to the literature

#let claim-block(paper, claim, ours) = block(
  width: 100%,
  inset: (left: 0.3em, top: 0.4em, bottom: 0.4em),
  stroke: (left: 1pt + sub-color),
  [
    #set par(first-line-indent: 0em)
    #strong[#paper] \
    #text(fill: sub-color)[#emph[Their measurement: ] #claim] \
    #text[#emph[Ours: ] #ours]
  ],
)

#claim-block(
  [Demers et al. 1987, "Epidemic Algorithms" (PODC)],
  [Anti-entropy converges to every node in #math.log #h(0pt) N rounds
   with high probability; metrics are #emph[residue], #emph[traffic],
   #emph[delay] (#math.italic[t_avg], #math.italic[t_last]).],
  [Reported as #math.italic[t_last] only (one #raw("convergence_millis")
   per run). At #math.italic[f] = 3 the curve hugs #math.log_2 N
   through N = 32 and dips below at N = 64.],
)

#claim-block(
  [Karp et al. 2000, "Randomized Rumor Spreading" (FOCS)],
  [Push-pull on the complete graph: #math.Theta(log_2 #h(0pt) N) rounds,
   #math.Theta(N log #h(0pt) log #h(0pt) N) messages; the latter is
   the address-oblivious lower bound.],
  [Gabion's peer-frontier dedup is #emph[not] address-oblivious — the
   sender carries per-receiver knowledge of acked sequences — so
   convergence below #math.log_2 #h(0pt) N at N ≥ 32 is consistent
   with the theorem.],
)

#claim-block(
  [Das, Gupta, Motivala 2002, "SWIM" (DSN)],
  [Detection time #math.T'/(1 - e^(-q #math.italic[f]) ) #math.approx
   1.6 #math.italic[T'] ; constant per-node load as N grows.],
  [Membership is delegated to the Kubernetes
   #raw("EndpointSlice") watcher; the structural analogue is
   per-node bandwidth, which is flat at ~4.3 kB/s from N = 32 to
   N = 64.],
)

#claim-block(
  [Leitão et al. 2007, "HyParView" (DSN) and "Plumtree" (SRDS)],
  [Active view size #math.approx log #h(0pt) N + #math.italic[c];
   >99% reliability at 80% kill; Plumtree's RMR metric quantifies
   message redundancy.],
  [Gabion does not implement membership. Its peer-frontier dedup
   plays Plumtree's role of suppressing already-delivered messages.
   RMR is a natural addition; the renderer already records bytes per
   novel delta.],
)

#claim-block(
  [Van Renesse, Birman, Vogels 2003, "Astrolabe" (TOCS)],
  [Aggregation tick #math.italic[ρ] #math.approx 5–10 s; ~5%
   aggregate error; propagation in tens of seconds across hierarchy
   levels.],
  [Gabion is a single-level mesh, not a hierarchy; with
   #math.italic[ρ] = 100 ms it propagates a write in sub-second
   wall-clock time even at N = 64.],
)

#claim-block(
  [Birman et al. 1999, "Bimodal Multicast" (TOCS)],
  [Stable delivery at up to ~25–30% packet loss; bimodal latency
   distribution under bursty load.],
  [Convergence at 50% i.i.d. loss with a +2-round penalty, no
   residual divergence in any trial.],
)

#claim-block(
  [Jelasity et al. 2007, "Gossip-based peer sampling" (TOCS)],
  [In-degree distribution skew; resilience under churn up to 10⁵
   nodes.],
  [Not measured here. The peer set is fixed per scenario; a churn
   suite using a sim implementation of #raw("PeerDiscovery") is the
   natural follow-up.],
)

